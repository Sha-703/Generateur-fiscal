{
  "appId": "com.dgrkc.app",
  "productName": "DGRKC - Générateur Fiscal",
  "executableName": "DGRKC",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "main.js",
    "preload.js",
    "index.html",
    "login.html",
    "script.js",
    "style.css",
    "assets/",
    "node_modules/"
  ],
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "DGRKC-Setup-${version}.exe"
  },
  "portable": {
    "artifactName": "DGRKC-Portable-${version}.exe"
  }
}
